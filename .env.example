# ================================
# CONFIGURATION AUTOPOST BACKEND
# ================================
# Copie ce fichier en .env et remplis les valeurs

# Serveur
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── BUFFER OAuth ──────────────────
# Créer une app sur buffer.com/developers
BUFFER_CLIENT_ID=
BUFFER_CLIENT_SECRET=
BUFFER_REDIRECT_URI=http://localhost:3000/auth/buffer/callback

# ── TWITTER / X ──────────────────
# Créer une app sur developer.twitter.com
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── LINKEDIN ─────────────────────
# Créer une app sur linkedin.com/developers
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# ── INSTAGRAM (via Meta API) ──────
# Créer une app sur developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
